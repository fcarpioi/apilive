{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "build": {
        "main": "index.mjs"
      },
      "serviceAccount": "firebase-adminsdk-fbsvc@live-copernico.iam.gserviceaccount.com",
      "region": "us-central1",
      "memory": "1GB",
      "timeoutSeconds": 540,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    },
    {
      "source": "functions_v2",
      "codebase": "v2",
      "build": {
        "main": "index.mjs"
      },
      "serviceAccount": "firebase-adminsdk-fbsvc@live-copernico.iam.gserviceaccount.com",
      "region": "us-central1",
      "memory": "2GB",
      "timeoutSeconds": 540,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
