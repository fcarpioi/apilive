rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // CMS sube media directamente desde el browser con Firebase Auth.
    match /cms-media/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // El resto: solo Admin SDK desde Cloud Functions.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
